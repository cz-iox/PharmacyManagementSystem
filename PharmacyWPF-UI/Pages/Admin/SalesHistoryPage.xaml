<Page x:Class="PharmacyWPF_UI.Pages.Admin.SalesHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="clr-namespace:PharmacyWPF_UI.Controls"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      mc:Ignorable="d"
      Title="Sales History"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,24,28,28">

            <TextBlock Text="Sales History"
                       FontFamily="Alexandria"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#3b413c"/>
            <TextBlock Text="Monthly transactions and revenue overview"
                       FontFamily="Alexandria"
                       FontSize="14"
                       Foreground="#8a9996"
                       Margin="0,6,0,0"/>

            <!-- Cards -->
            <Grid Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <controls:StatCardControl x:Name="MonthlyCustomers"
                                          Grid.Column="0"
                                          Title="Monthly Customers"
                                          ShowTrend="False"
                                          IconKind="AccountCash"/>

                <controls:StatCardControl x:Name="MonthTransactions"
                                          Grid.Column="1"
                                          Title="This Month Revenue"
                                          ShowTrend="False"
                                          IconKind="Cash"/>
            </Grid>

            <!-- Search -->
            <Grid Margin="0,16,0,0">
                <TextBox x:Name="SearchBox"
                         Height="36" Padding="10,0,10,0"
                         FontSize="13"
                         Background="#F9FAFB"
                         Foreground="#3b413c"
                         BorderBrush="#c4d9d6"
                         BorderThickness="1"
                         VerticalContentAlignment="Center"
                         FontFamily="Alexandria"
                         TextChanged="SearchBox_TextChanged"/>
                <iconPacks:PackIconMaterial Kind="Magnify"
                                            x:Name="SearchIcon"
                                            Width="16" Height="16"
                                            Foreground="#8a9996"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Margin="0,0,12,0"
                                            IsHitTestVisible="False"/>
                <TextBlock Text="Search by customer, medicine, or ID..."
                           IsHitTestVisible="False"
                           FontFamily="Alexandria"
                           FontSize="13"
                           Foreground="#8a9996"
                           Margin="12,0,36,0"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Text, ElementName=SearchBox}" Value=""/>
                                        <Condition Binding="{Binding IsFocused, ElementName=SearchBox}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <!-- Transactions Table -->
            <Border Margin="0,16,0,0"
                    Background="White"
                    BorderBrush="#c4d9d6"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="24,20">
                <StackPanel>
                    <TextBlock Text="Recent Transactions"
                               FontFamily="Alexandria"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#3b413c"
                               Margin="0,0,0,16"/>

                    <DataGrid x:Name="SalesGrid"
                              Style="{StaticResource ModernDataGridStyle}"
                              ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}"
                              RowStyle="{StaticResource ModernDataGridRowStyle}"
                              MinHeight="320">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="TRANSACTION ID"
                                                Binding="{Binding TransactionId}"
                                                Width="120"
                                                FontFamily="Alexandria"/>
                            <DataGridTextColumn Header="CUSTOMER"
                                                Binding="{Binding CustomerName}"
                                                Width="*"
                                                FontFamily="Alexandria"/>
                            <DataGridTextColumn Header="MEDICINE"
                                                Binding="{Binding MedicineName}"
                                                Width="*"
                                                FontFamily="Alexandria"/>
                            <DataGridTextColumn Header="QTY"
                                                Binding="{Binding Quantity}"
                                                Width="60"
                                                FontFamily="Alexandria"/>
                            <DataGridTemplateColumn Header="TOTAL" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding TotalPrice}"
                                                   FontFamily="Alexandria"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#085041"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="PHARMACIST"
                                                Binding="{Binding PharmacistName}"
                                                Width="*"
                                                FontFamily="Alexandria"/>
                            <DataGridTextColumn Header="DATE"
                                                Binding="{Binding Date}"
                                                Width="130"
                                                FontFamily="Alexandria"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>